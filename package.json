{
  "name": "subsidy-apply-system",
  "version": "1.0.0",
  "description": "대국민 선착순 금융 지원금 신청 및 대용량 관리자 집계 시스템",
  "main": "dist/api/server.js",
  "scripts": {
    "dev:api": "tsx watch src/api/server.ts",
    "dev:worker": "tsx watch src/worker/worker.ts",
    "build": "tsc",
    "start:api": "node dist/api/server.js",
    "start:worker": "node dist/worker/worker.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "seed": "tsx scripts/seed.ts",
    "loadtest:reset": "tsx scripts/reset-load-test.ts",
    "loadtest:good": "k6 run scripts/k6/apply-good.js",
    "loadtest:good:smoke": "K6_PROFILE=smoke k6 run scripts/k6/apply-good.js",
    "loadtest:bad": "k6 run scripts/k6/apply-bad.js",
    "loadtest:bad:smoke": "K6_PROFILE=smoke k6 run scripts/k6/apply-bad.js",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "bullmq": "^5.34.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "mysql2": "^3.12.0",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "redlock": "^5.0.0-beta.2",
    "sequelize": "^6.37.5",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
